# ===== Python sidecar (Render service #1) =====
# Required. Long random string. Same value must be set on the Node bot.
VRF_API_KEY=replace-with-a-long-random-string

# ===== Node bot (Render service #2, existing) =====
# Base URL of the sidecar, no trailing slash.
VRF_SIDECAR_URL=https://your-vrf-sidecar.onrender.com
# Same secret as the sidecar's VRF_API_KEY.
VRF_API_KEY=replace-with-a-long-random-string
# Needed only for image/PDF schedule intake.
ANTHROPIC_API_KEY=sk-ant-...

# Optional extraction model overrides (defaults shown).
# Default extractor is cheap Haiku; transcription-grade work.
VRF_EXTRACT_MODEL=claude-haiku-4-5-20251001
# Bump just the image path to Sonnet if field photos are messy:
# VRF_EXTRACT_MODEL_IMAGE=claude-sonnet-4-6
# VRF_EXTRACT_MODEL_PDF=claude-haiku-4-5-20251001

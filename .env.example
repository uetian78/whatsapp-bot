# ===== Copy to ".env" and fill in =====

# Secret string you invent (webhook verification)
VERIFY_TOKEN=put_any_secret_here

# From Meta WhatsApp dashboard
WHATSAPP_TOKEN=your_meta_token
PHONE_NUMBER_ID=your_phone_number_id

# From console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# The ID in your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your_sheet_id

# The ENTIRE service-account JSON file, pasted as ONE line.
# (From Google Cloud -> Service Account -> Keys -> Add Key -> JSON)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com"}

PORT=3000
